// tsconfig.json
// This file is used to specify the root files and the compiler options required to 
// compile the project.

{       
  "compilerOptions": {    
    "module": "NodeNext",
    "target": "ES2022",
    "types": [],    
    "sourceMap": true,
    "declaration": true,      
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,    
    "strict": true,    
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "src/*": ["./src/*"]
    },
    "removeComments": false,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true
  },
  "include": ["src/**/*.ts", "main.ts", "test/**/*"],
  "exclude": ["node_modules","dist","tests"]
}
